<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#090b18" />
  <title>Flip 7 Score</title>
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icons/icon-192.png" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div id="app" class="app-shell">
    <header class="topbar">
      <button class="icon-btn" id="menuBtn" aria-label="Menu">☰</button>
      <div class="brand">FLIP<span>7</span></div>
      <div class="round-pill" id="roundPill">Setup</div>
    </header>

    <main>
      <section class="screen active" id="screen-players">
        <div class="screen-title">👥 Participantes</div>
        <p class="subtitle">Adicione os nomes de quem vai jogar.</p>
        <div class="player-form">
          <input id="playerNameInput" type="text" placeholder="Nome do participante" autocomplete="off" />
          <button id="addPlayerBtn">Adicionar</button>
        </div>
        <div id="playersList" class="players-list"></div>
        <button id="startGameBtn" class="primary big">▶ Iniciar partida</button>
      </section>

      <section class="screen" id="screen-ranking">
        <div class="ranking-head">
          <div>
            <div class="screen-title">🏆 Ranking</div>
            <p class="subtitle">Primeiro a 200 pontos vence.</p>
          </div>
        </div>
        <div id="rankingList" class="ranking-list table-mode"></div>
        <button id="goRoundBtn" class="primary big">Encerrar rodada</button>
        <div class="two-actions">
          <button id="goHistoryBtn" class="secondary">▦ Histórico</button>
          <button id="goChampionsBtn" class="secondary">♛ Campeões</button>
        </div>
        <button id="undoBtn" class="ghost">↶ Desfazer última rodada</button>
      </section>

      <section class="screen" id="screen-round">
        <button class="back-btn" data-go="ranking">‹ Voltar</button>
        <div class="screen-title">Encerrar rodada</div>
        <p class="subtitle" id="roundSubtitle">Digite os pontos da rodada.</p>
        <div id="roundInputs" class="round-inputs"></div>
        <div class="hint"><span class="bomb">💣</span><div><strong>Estourou?</strong><br>Toque na bomba para marcar 0 ponto para o jogador.</div></div>
        <button id="saveRoundBtn" class="success big">✓ Salvar e atualizar</button>
      </section>

      <section class="screen" id="screen-feedback">
        <div class="confetti" aria-hidden="true"></div>
        <div class="trophy">🏆</div>
        <div id="feedbackTitle" class="feedback-title">Nova líder!</div>
        <p id="feedbackText" class="subtitle center"></p>
        <div id="feedbackCard" class="winner-card"></div>
        <button id="finishGameBtn" class="success big hidden">🏆 Encerrar jogo</button>
        <button id="feedbackRankingBtn" class="primary big">Voltar para o ranking</button>
        <button id="feedbackHistoryBtn" class="secondary full">Ver histórico da partida</button>
      </section>

      <section class="screen" id="screen-history">
        <button class="back-btn" data-go="ranking">‹ Voltar</button>
        <div class="screen-title">▦ Histórico das rodadas</div>
        <p class="subtitle">Pontuação de cada jogador por rodada.</p>
        <div class="history-wrap">
          <table id="historyTable"></table>
        </div>
      </section>

      <section class="screen" id="screen-champions">
        <button class="back-btn" data-go="ranking">‹ Voltar</button>
        <div class="screen-title">♛ Campeões</div>
        <p class="subtitle">Lista de campeões das partidas finalizadas.</p>
        <div id="championsList" class="champions-list"></div>
      </section>
    </main>

    <nav class="bottom-nav">
      <button data-go="ranking" class="nav-item active">🏆<span>Ranking</span></button>
      <button data-go="round" class="nav-item">✎<span>Encerrar</span></button>
      <button data-go="history" class="nav-item">▦<span>Histórico</span></button>
      <button data-go="champions" class="nav-item">♛<span>Campeões</span></button>
    </nav>
  </div>

  <script src="app.js"></script>
</body>
</html>
